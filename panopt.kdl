// PANopt cockpit layout for Zellij.
//
// Left: five plugin panes stacked vertically (25% column), one per resource
// kind - todos, agents, terminals, commands, scratchpads. Each is its own
// Zellij plugin instance running the same wasm with a distinct `mode` value;
// they are pinned full-height by the `ui` tab template.
// Right: a single content pane the five plugin panes swap into.
//
// This is a static reference layout. `panopt up` generates its own equivalent;
// see `crates/panopt/src/up.rs`.
//
// Start Zellij from inside the workspace folder so the plugin's `/host` mount
// resolves to it:  cd <workspace> && zellij --layout /Users/user/p/panopt/panopt.kdl
layout {
    // The fixed shell of every tab: five plugin panes pinned left, content
    // pane on the right flows into the `children` slot.
    tab_template name="ui" {
        pane split_direction="vertical" {
            pane size="25%" split_direction="horizontal" {
                pane size="30%" {
                    plugin location="file:/Users/user/p/panopt/crates/panopt-zellij/target/wasm32-wasip1/release/panopt-zellij.wasm" {
                        mode "todos"
                    }
                }
                pane size="15%" {
                    plugin location="file:/Users/user/p/panopt/crates/panopt-zellij/target/wasm32-wasip1/release/panopt-zellij.wasm" {
                        mode "agents"
                    }
                }
                pane size="15%" {
                    plugin location="file:/Users/user/p/panopt/crates/panopt-zellij/target/wasm32-wasip1/release/panopt-zellij.wasm" {
                        mode "terminals"
                    }
                }
                pane size="15%" {
                    plugin location="file:/Users/user/p/panopt/crates/panopt-zellij/target/wasm32-wasip1/release/panopt-zellij.wasm" {
                        mode "commands"
                    }
                }
                pane size="25%" {
                    plugin location="file:/Users/user/p/panopt/crates/panopt-zellij/target/wasm32-wasip1/release/panopt-zellij.wasm" {
                        mode "scratchpads"
                    }
                }
            }
            pane {
                children
            }
        }
    }

    // Initial state: the five plugin panes plus one content pane.
    ui {
        pane focus=true
    }
}
