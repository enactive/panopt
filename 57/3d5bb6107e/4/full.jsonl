","ExitPlanMode","ExitWorktree","LSP","Monitor","NotebookEdit","PushNotification","RemoteTrigger","TaskCreate","TaskGet","TaskList","TaskOutput","TaskStop","TaskUpdate","WebFetch","WebSearch","mcp__claude_ai_Gmail__authenticate","mcp__claude_ai_Gmail__complete_authentication","mcp__claude_ai_Google_Calendar__authenticate","mcp__claude_ai_Google_Calendar__complete_authentication","mcp__claude_ai_Google_Drive__authenticate","mcp__claude_ai_Google_Drive__complete_authentication","mcp__panopt__agent_leave","mcp__panopt__agent_list","mcp__panopt__agent_tool_create","mcp__panopt__agent_tool_delete","mcp__panopt__agent_tool_get","mcp__panopt__agent_tool_list","mcp__panopt__agent_tool_update","mcp__panopt__id_kind","mcp__panopt__identify","mcp__panopt__lock_acquire","mcp__panopt__lock_release","mcp__panopt__lock_status","mcp__panopt__process_create","mcp__panopt__process_delete","mcp__panopt__process_get","mcp__panopt__process_list","mcp__panopt__process_update","mcp__panopt__scratchpad_append","mcp__panopt__scratchpad_create","mcp__panopt__scratchpad_delete","mcp__panopt__scratchpad_get","mcp__panopt__scratchpad_list","mcp__panopt__scratchpad_read","mcp__panopt__scratchpad_tags_list","mcp__panopt__scratchpad_update","mcp__panopt__todo_add_blocker","mcp__panopt__todo_comment_add","mcp__panopt__todo_comment_delete","mcp__panopt__todo_comment_update","mcp__panopt__todo_complete","mcp__panopt__todo_create","mcp__panopt__todo_delete","mcp__panopt__todo_get","mcp__panopt__todo_list","mcp__panopt__todo_lock","mcp__panopt__todo_remove_blocker","mcp__panopt__todo_set_blockers","mcp__panopt__todo_start","mcp__panopt__todo_tags_list","mcp__panopt__todo_unlock","mcp__panopt__todo_update","mcp__panopt__whoami"],"removedNames":[],"readdedNames":[],"pendingMcpServers":[]},"type":"attachment","uuid":"25ee6c9e-fef8-4ea9-9eac-2e46b70d0a96","timestamp":"2026-05-27T21:11:03.677Z","userType":"external","entrypoint":"cli","cwd":"/home/gregz/cp/panopt","sessionId":"c43a6957-bc1c-4d96-a471-5cd40e